---
import '../styles/global.css';

import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ClientsMarquee from '../components/ClientsMarquee.astro';
import ClientsShowcase from '../components/ClientsShowcase.astro';
import PortfolioSection from '../components/portfolio/PortfolioSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import FaviconLinks from '../components/FaviconLinks.astro';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<FaviconLinks />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="theme-color" content="#070707" />
		<meta name="theme-color" media="(prefers-color-scheme: light)" content="#070707" />
		<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#070707" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black" />
		<meta name="generator" content={Astro.generator} />
		<title>MR Films - Portfolio Audiovisual</title>
		<meta
			name="description"
			content="MR Films — portfolio audiovisual premium: video, foto, diseño y producción con IA para marcas, eventos y proyectos automotrices."
		/>
	</head>
	<body>
		<Nav />
		<main>
			<div class="home-intro">
				<Hero
					title="MR Films"
					tagline="Photography - Videography - Design - AI Production"
					image={{
						src: '/images/MedellinCityPortada.jpg',
						alt: 'MR Films — Medellin, ciudad y horizonte al atardecer'
					}}
					scrollHref="#portfolio"
				/>

				<ClientsMarquee />
			</div>
			<PortfolioSection />
			<ClientsShowcase />
			<ContactSection />
		</main>

		<Footer />
	</body>
</html>
