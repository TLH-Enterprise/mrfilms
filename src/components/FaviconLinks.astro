---
/** Bump when favicon assets change so browsers reload (favicons cache aggressively). */
const v = '1';
---

<link rel="icon" href={`/favicon.ico?v=${v}`} type="image/x-icon" />
<link rel="shortcut icon" href={`/favicon.ico?v=${v}`} type="image/x-icon" />
<link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${v}`} />
