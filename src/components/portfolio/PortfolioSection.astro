---
type HighlightVideo = {
  title: string;
  videoSrc: string;
  posterSrc: string;
};

type UpcomingPreview = {
  title: string;
  category: string;
  previewSrc: string;
};

// Cambia estas 3 entradas por tus mejores videos (paths en /public/videos/highlights/...)
const highlightVideos: HighlightVideo[] = [
  {
    title: "Podium BC Event",
    videoSrc: "/videos/highlights/podium-bc-event.mp4",
    posterSrc: "/images/about-me/03.jpg",
  },
  {
    title: "SF90 x G63 BRABUS",
    videoSrc: "/videos/highlights/sf90-g63-brabus.mp4",
    posterSrc: "/images/about-me/04.jpg",
  },
  {
    title: "Legends Never Fade - AI Film",
    videoSrc: "/videos/highlights/legends-never-fade.mp4",
    posterSrc: "/images/about-me/05.jpg",
  },
];

const upcomingPreviews: UpcomingPreview[] = [
  {
    title: "Túnica en Dubai - Emmus",
    category: "Video Musical",
    previewSrc: "/images/about-me/01.jpg",
  },
  {
    title: "Rubia - Jhayozbb",
    category: "Video Musical",
    previewSrc: "/images/about-me/02.jpg",
  },
  {
    title: "Verte de nuevo - RiozG",
    category: "Video Musical",
    previewSrc: "/images/about-me/06.jpg",
  },
];
---

<section id="portfolio" class="portfolio-zone">
  <div class="container">
    <div class="portfolio-headline-action">
      <a class="portfolio-pill" href="/portfolio">Ver portfolio</a>
    </div>

    <div class="portfolio-highlights">
      {
        highlightVideos.map((video) => (
          <article class="portfolio-video-card">
            <div class="portfolio-video-frame">
              <video
                class="portfolio-video"
                src={video.videoSrc}
                poster={video.posterSrc}
                muted
                loop
                playsinline
                preload="metadata"
                controls
              >
                Tu navegador no soporta video HTML5.
              </video>
            </div>
            <h3 class="portfolio-video-title">{video.title}</h3>
          </article>
        ))
      }
    </div>

    <div class="portfolio-upcoming">
      <div class="section-head">
        <h3 class="portfolio-upcoming-title">Proximamente</h3>
      </div>

      <div class="portfolio-upcoming-grid">
        {
          upcomingPreviews.map((item) => (
            <article class="portfolio-upcoming-card">
              <img
                class="portfolio-upcoming-image"
                src={item.previewSrc}
                alt={`${item.title} - preview`}
                loading="lazy"
                decoding="async"
              />
              <div class="portfolio-upcoming-meta">
                <p class="portfolio-upcoming-category">{item.category}</p>
                <h4 class="portfolio-upcoming-item-title">{item.title}</h4>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
