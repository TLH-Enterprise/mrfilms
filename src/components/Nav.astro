---
const pathname = Astro.url.pathname;

const links: Array<{ href: string; label: string }> = [
	{ href: '/', label: 'Inicio' },
	{ href: '/#portfolio', label: 'Portfolio' },
	{ href: '/sobre-mi', label: 'Sobre mi' },
	{ href: '/#contact', label: 'Contacto' }
];

function isActive(href: string): boolean {
	if (href === '/sobre-mi') return pathname === '/sobre-mi';
	if (href === '/') return pathname === '/';
	return false;
}
---

<header class="nav" data-mobile-nav>
	<div class="container nav-wrap">
		<a href="/" class="brand">
			<img
				class="brand-logo"
				src="/logo-mr-films.svg"
				alt="MR Films"
				width="200"
				height="40"
				loading="eager"
				decoding="async"
			/>
		</a>
		<div class="nav-scroll">
			<nav class="nav-links" aria-label="Principal">
				{
					links.map((l) => (
						<a href={l.href} class:list={['nav-link', isActive(l.href) && 'nav-link--active']}>
							{l.label}
						</a>
					))
				}
			</nav>
		</div>
	</div>
</header>

<script>
	(() => {
		const nav = document.querySelector('[data-mobile-nav]');
		if (!nav) return;

		const mobileQuery = window.matchMedia('(max-width: 900px)');
		let lastY = window.scrollY;
		let ticking = false;

		const onScroll = () => {
			if (!mobileQuery.matches) {
				nav.classList.remove('nav--hidden');
				lastY = window.scrollY;
				return;
			}

			const y = window.scrollY;
			const delta = y - lastY;

			// En top siempre visible
			if (y <= 8) {
				nav.classList.remove('nav--hidden');
				lastY = y;
				return;
			}

			// Scroll abajo: ocultar | scroll arriba: mostrar
			if (delta > 6) nav.classList.add('nav--hidden');
			else if (delta < -6) nav.classList.remove('nav--hidden');

			lastY = y;
		};

		window.addEventListener(
			'scroll',
			() => {
				if (ticking) return;
				ticking = true;
				window.requestAnimationFrame(() => {
					onScroll();
					ticking = false;
				});
			},
			{ passive: true }
		);

		window.addEventListener('resize', onScroll, { passive: true });
	})();
</script>
