---
export interface HeroProps {
	title: string;
	image: { src: string; alt: string };
	/** Línea pequeña bajo el título (servicios / disciplinas) */
	tagline?: string;
	/** Ancla al hacer clic en SCROLL (p. ej. #portfolio) */
	scrollHref?: string;
}

const {
	title,
	image,
	tagline = 'Photography - Videography - Design - AI Production',
	scrollHref = '#portfolio'
} = Astro.props as HeroProps;
---

<section class="hero hero--with-bg">
	<div class="hero-bg" aria-hidden="true">
		<img
			src={image.src}
			alt={image.alt}
			width="1920"
			height="1080"
			fetchpriority="high"
			class="hero-bg-img"
		/>
	</div>
	<div class="hero-scrim" aria-hidden="true" />

	<div class="hero-cover">
		<div class="hero-cover__main">
			<div class="container hero-inner hero-inner--center">
				<h1>{title}</h1>
				<div class="eyebrow hero-eyebrow">{tagline}</div>
			</div>
		</div>

		<a href={scrollHref} class="hero-scroll" aria-label="Desplazar a la sección portfolio en esta página">
			<span class="hero-scroll__line" aria-hidden="true"></span>
			<span class="hero-scroll__text">SCROLL</span>
		</a>
	</div>
</section>
